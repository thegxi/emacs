;;; init.el --- Basic Editor  Configuration -*- lexical-binding: t -*-

;; --- 1. 行号设置 ---
(setq display-line-numbers-type 'relative)  ; 使用相对行号
(global-display-line-numbers-mode t)        ; 全局开启

;; 禁用不需要行号的模式 (terminal, dashboard)
(dolist (mode '(org-mode-hook
		term-mode-hook
		shell-mode-hook
		eshell-mode-hook))
  (add-hook mode (lambda () (display-line-numbers-mode 0))))

;; --- 2. 缩进设置 (Tab = 2) ---
(setq-default indent-tabs-mode nil)  ; 使用空格代替 Tab
(setq-default tab-width 2)           ; Tab 宽度设置为 2
(setq-default standard-indent 2)     ; 标准缩进设置为 2
(setq-default c-basic-offset 2)      ; C 语言系列缩进为 2


;; --- 3. 自动高亮括号与括号匹配 ---
(electric-pair-mode t)               ; 自动补全括号（Emacs 内置）
(show-paren-mode t)                  ; 高亮匹配的括号


;; --- 4. 文本编码与换行 ---
(setq-default buffer-file-coding-system 'utf-8-unix)
(setq-default fill-column 80)        ; 默认每行 80 字符换行
(global-auto-revert-mode t)          ; 外部修改文件后自动刷新 Buffer

;; --- 5. 搜索与交互 ---
(setq search-highlight t)            ; 搜索高亮
(setq query-replace-highlight t)     ; 替换高亮
(setq isearch-lazy-highlight t)
(setq-default case-fold-search t)    ; 搜索时忽略大小写

;; --- 6. 交互优化 ---
(setq use-short-answers t)           ; 将 yes/no 改为 y/n
(setq scroll-step 1                  ; 平滑滚动，每次一行
      scroll-conservatively 10000)
;; 设置 Maple Mono Font，字号 15 (150 = 15pt)
(set-face-attribute 'default nil
                    :family "Maple Mono"
                    :height 150)
;; 如果希望所有 Frame 都生效，把字体加入默认列表
(add-to-list 'default-frame-alist '(font . "Maple Mono-15"))

(provide 'init)
